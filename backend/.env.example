# ChatGPT üyeliği API anahtarı DEĞİLDİR.
# Buraya OpenAI API key yazın: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Kaynak analizi + transkript indeksleme için model (ucuz, hızlı)
OPENAI_MODEL=gpt-4.1-mini

# Canlı AI yanıt için model (isteğe bağlı; daha yetenekli model kullanabilirsiniz)
# Boş bırakılırsa OPENAI_MODEL kullanılır.
# Daha hızlı/ucuz: gpt-4.1-mini | Daha kaliteli: gpt-4.1 | En hızlı: gpt-4.1-nano
OPENAI_RESPOND_MODEL=gpt-4.1-mini

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
